# IRT Backtest Worker Configuration
# Copy this file to .env and adjust the values for your environment.

# URL of the IRT API (the worker polls this for pending jobs)
IRT_API_URL=http://localhost:8000

# Seconds between poll cycles when no work is available
WORKER_POLL_INTERVAL=5

# Maximum seconds a backtest subprocess may run before being killed
WORKER_JOB_TIMEOUT=300

# Number of parallel worker slots (threads) for concurrent backtest execution
WORKER_NUM_SLOTS=3

# Absolute path to the historical price data directory on the host machine
HIST_DATA_PATH=C:/Users/YourUser/path/to/data_futuros

# Path to the backtest engine's main.py entry point (relative to IRT project root)
ENGINE_PATH=packages/backtest-engine/main.py
